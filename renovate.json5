{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^hack\\/e2e\\.sh$/"],
      "matchStrings": [
        "# renovate: datasource=docker depName=alpine versioning=docker\\s+E2E_ALPINE_IMAGE=\\$\\{E2E_ALPINE_IMAGE:-alpine:(?<currentValue>[^@}]+)@(?<currentDigest>sha256:[a-f0-9]+)\\}"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "alpine",
      "versioningTemplate": "docker"
    }
  ]
}
